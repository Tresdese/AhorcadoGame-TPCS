<Window x:Class="ClienteAhorcado.VentanaPartidas"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ClienteAhorcado"
        xmlns:p="clr-namespace:ClienteAhorcado.Properties"
        mc:Ignorable="d"
        Title="{x:Static p:Resources.Partidas_TituloVentana}" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen" Background="White">

    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Margin="20,15,20,10">
            <StackPanel HorizontalAlignment="Left" VerticalAlignment="Center">
                <TextBlock Text="{x:Static p:Resources.Partidas_Titulo}" FontSize="20" FontWeight="Bold"/>
                <TextBlock Text="{x:Static p:Resources.Partidas_Subtitulo}" FontSize="13" Foreground="#666666"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                <Button x:Name="btnIdioma" Click="btnIdioma_Click" Padding="10,5" Background="White" Foreground="Black" BorderBrush="#CCCCCC" BorderThickness="1" FontSize="13" Margin="0,0,10,0">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <Button x:Name="btnUsuario" Content="Usuario ▼" Padding="10,5" Background="#333333" Foreground="White"
                        BorderThickness="0" FontSize="13" Click="btnUsuario_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="20"/>
                        </Style>
                    </Button.Resources>
                    <Button.ContextMenu>
                        <ContextMenu x:Name="menuUsuario">
                            <MenuItem x:Name="mnuVerPerfil" Header="{x:Static p:Resources.Partidas_VerPerfil}" Click="mnuVerPerfil_Click"/>
                            <MenuItem x:Name="mnuHistorial" Header="{x:Static p:Resources.Partidas_HistorialPuntajes}" Click="mnuHistorial_Click"/>
                            <Separator/>
                            <MenuItem x:Name="mnuCerrarSesion" Header="{x:Static p:Resources.Partidas_CerrarSesion}" Foreground="Red" Click="mnuCerrarSesion_Click"/>
                        </ContextMenu>
                    </Button.ContextMenu>
                </Button>
            </StackPanel>
        </Grid>

        <Border Grid.Row="0" BorderBrush="#EEEEEE" BorderThickness="0,0,0,1"/>

        <Grid Grid.Row="1" Margin="20,10,20,10">
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                <Border Background="#E8F5E9" BorderBrush="#A5D6A7" BorderThickness="1" CornerRadius="15" Padding="10,5" Margin="0,0,10,0">
                    <StackPanel Orientation="Horizontal">
                        <Ellipse Width="8" Height="8" Fill="Green" Margin="0,0,6,0" VerticalAlignment="Center"/>
                        <TextBlock x:Name="lblContadorPartidas" Text="" FontSize="13" Foreground="#2E7D32"/>
                    </StackPanel>
                </Border>
                <Border Background="#F5F5F5" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="15" Padding="10,5" Margin="0,0,15,0">
                    <TextBlock x:Name="lblPuntaje" Text="{x:Static p:Resources.Partidas_PuntajePrefijo}" FontSize="13" Foreground="#333333"/>
                </Border>
                <TextBlock Text="{x:Static p:Resources.Partidas_DosJugadores}" FontSize="13" Foreground="#888888" VerticalAlignment="Center"/>
            </StackPanel>
            <StackPanel Orientation="Horizontal" HorizontalAlignment="Right">
                <Button x:Name="btnActualizar" Content="⟳" ToolTip="Actualizar" Padding="12,8" Margin="0,0,10,0"
                        Background="#F0F0F0" Foreground="#333333" BorderBrush="#CCCCCC" BorderThickness="1" FontSize="16" Click="btnActualizar_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <Button x:Name="btnCrearPartida" Content="{x:Static p:Resources.Partidas_CrearPartida}"
                        Padding="15,8" Background="#0078D4" Foreground="White" BorderThickness="0" FontSize="14" FontWeight="Bold" Click="btnCrearPartida_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>
        </Grid>

        <Border Grid.Row="2" Margin="20,0,20,20" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="8">
            <Grid>
                <Grid.RowDefinitions>
                    <RowDefinition Height="Auto"/>
                    <RowDefinition Height="*"/>
                </Grid.RowDefinitions>

                <Grid Grid.Row="0" Background="#F9F9F9">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="2*"/>
                        <ColumnDefinition Width="1.5*"/>
                        <ColumnDefinition Width="1*"/>
                        <ColumnDefinition Width="1*"/>
                    </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{x:Static p:Resources.Partidas_ColCreador}" FontSize="12" FontWeight="Bold" Foreground="#666666" Margin="15,10,0,10"/>
                        <TextBlock Grid.Column="1" Text="{x:Static p:Resources.Comun_CorreoElectronico}" FontSize="12" FontWeight="Bold" Foreground="#666666" Margin="10,10,0,10"/>
                        <TextBlock Grid.Column="2" Text="{x:Static p:Resources.Partidas_ColCreada}" FontSize="12" FontWeight="Bold" Foreground="#666666" Margin="10,10,0,10"/>
                        <TextBlock Grid.Column="3" Text="{x:Static p:Resources.Partidas_ColJugadores}" FontSize="12" FontWeight="Bold" Foreground="#666666" Margin="10,10,0,10"/>
                        <TextBlock Grid.Column="4" Text="" Margin="10,10,0,10"/>
                </Grid>

                <ListView x:Name="lvPartidas" Grid.Row="1" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                    <ListView.ItemContainerStyle>
                        <Style TargetType="ListViewItem">
                            <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                            <Setter Property="Padding" Value="0"/>
                            <Setter Property="BorderBrush" Value="#EEEEEE"/>
                            <Setter Property="BorderThickness" Value="0,0,0,1"/>
                        </Style>
                    </ListView.ItemContainerStyle>
                    <ListView.ItemTemplate>
                        <DataTemplate>
                            <Grid Margin="0,8,0,8">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="1*"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="{Binding Creador}" FontSize="14" FontWeight="Bold" Margin="15,0,0,0" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="1" Text="{Binding Correo}" FontSize="14" Foreground="#555555" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="2" Text="{Binding Creada}" FontSize="14" Foreground="#555555" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                <TextBlock Grid.Column="3" Text="1 / 2" FontSize="14" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                <Button Grid.Column="4" Content="{x:Static p:Resources.Partidas_Unirme}" Background="#0078D4" Foreground="White" BorderThickness="0"
                                        Padding="12,6" FontSize="13" Margin="5,0,15,0" VerticalAlignment="Center" Click="btnUnirme_Click">
                                        <Button.Resources>
                                        <Style TargetType="Border">
                                            <Setter Property="CornerRadius" Value="5"/>
                                        </Style>
                                    </Button.Resources>
                                </Button>
                            </Grid>
                        </DataTemplate>
                    </ListView.ItemTemplate>
                </ListView>
            </Grid>
        </Border>
    </Grid>
</Window>