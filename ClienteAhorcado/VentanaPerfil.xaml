<Page x:Class="ClienteAhorcado.VentanaPerfil"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ClienteAhorcado"
        xmlns:p="clr-namespace:ClienteAhorcado.Properties"
        mc:Ignorable="d" Background="#F0F0F0">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Background="White" Margin="0,0,0,1">
            <Border BorderBrush="#EEEEEE" BorderThickness="0,0,0,1">
                <Grid Margin="20,12,20,12">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                        <Button Content="{x:Static p:Resources.Comun_Volver}" Padding="10,5" Background="White" Foreground="Black" BorderBrush="#CCCCCC" BorderThickness="1" FontSize="13" Margin="0,0,15,0" Click="btnVolver_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="5"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                        <StackPanel>
                            <TextBlock Text="{x:Static p:Resources.Perfil_Titulo}" FontSize="16" FontWeight="Bold"/>
                            <TextBlock Text="{x:Static p:Resources.Perfil_Subtitulo}" FontSize="12" Foreground="#666666"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button x:Name="btnIdioma" Click="btnIdioma_Click" Padding="10,5" Background="White" Foreground="Black" BorderBrush="#CCCCCC" BorderThickness="1" FontSize="13" Margin="0,0,10,0">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="5"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                        <Button x:Name="btnUsuario" Content="Usuario ▼" Padding="10,5" Background="#333333" Foreground="White" BorderThickness="0" FontSize="13">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="20"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="20">
            <Border Background="White" CornerRadius="8" Padding="30">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" Opacity="0.08" ShadowDepth="2"/>
                </Border.Effect>
                <StackPanel>
                    <Grid Margin="0,0,0,25">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="lblNombreEncabezado" Text="" FontSize="18" FontWeight="Bold"/>
                                <TextBlock x:Name="lblCorreoEncabezado" Text="" FontSize="13" Foreground="#666666"/>
                            </StackPanel>
                        </StackPanel>
                        <Button Content="{x:Static p:Resources.Perfil_EditarPerfil}" HorizontalAlignment="Right" VerticalAlignment="Center" Padding="15,8" Background="#0078D4" Foreground="White" BorderThickness="0" FontSize="13" Click="btnEditarPerfil_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="5"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </Grid>
                    <TextBlock Text="{x:Static p:Resources.RegistrarCuenta_NombreCompleto}" FontSize="13" Foreground="#555555" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtNombre" FontSize="14" Height="40" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#DDDDDD" BorderThickness="1" IsReadOnly="True" Background="#F9F9F9">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>
                    <Grid Margin="0,15,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{x:Static p:Resources.Comun_CorreoElectronico}" FontSize="13" Foreground="#555555" Margin="0,0,0,5"/>
                            <TextBox x:Name="txtCorreo" FontSize="14" Height="40" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#DDDDDD" BorderThickness="1" IsReadOnly="True" Background="#F9F9F9">
                                <TextBox.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="5"/>
                                    </Style>
                                </TextBox.Resources>
                            </TextBox>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{x:Static p:Resources.RegistrarCuenta_FechaNacimiento}" FontSize="13" Foreground="#555555" Margin="0,0,0,5"/>
                            <TextBox x:Name="txtFechaNacimiento" FontSize="14" Height="40" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#DDDDDD" BorderThickness="1" IsReadOnly="True" Background="#F9F9F9">
                                <TextBox.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="5"/>
                                    </Style>
                                </TextBox.Resources>
                            </TextBox>
                        </StackPanel>
                    </Grid>
                    <TextBlock Text="{x:Static p:Resources.RegistrarCuenta_NumeroCelular}" FontSize="13" Foreground="#555555" Margin="0,15,0,5"/>
                    <TextBox x:Name="txtCelular" FontSize="14" Height="40" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#DDDDDD" BorderThickness="1" IsReadOnly="True" Background="#F9F9F9" Width="390" HorizontalAlignment="Left">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>
                    <Grid Margin="0,25,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <Border Grid.Column="0" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="5" Padding="15" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock x:Name="lblPuntajeTotal" Text="0 pts" FontSize="22" FontWeight="Bold" Foreground="#0078D4"/>
                                <TextBlock Text="{x:Static p:Resources.Perfil_PuntajeTotal}" FontSize="11" Foreground="#888888" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="1" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="5" Padding="15" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock x:Name="lblPartidasGanadas" Text="0" FontSize="22" FontWeight="Bold" Foreground="Green"/>
                                <TextBlock Text="{x:Static p:Resources.Perfil_PartidasGanadas}" FontSize="11" Foreground="#888888" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="2" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="5" Padding="15" Margin="0,0,10,0">
                            <StackPanel>
                                <TextBlock x:Name="lblRivalVencido" Text="0" FontSize="22" FontWeight="Bold" Foreground="#333333"/>
                                <TextBlock Text="{x:Static p:Resources.Perfil_RivalVencido}" FontSize="11" Foreground="#888888" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                        <Border Grid.Column="3" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="5" Padding="15">
                            <StackPanel>
                                <TextBlock x:Name="lblPenalizaciones" Text="0" FontSize="22" FontWeight="Bold" Foreground="Red"/>
                                <TextBlock Text="{x:Static p:Resources.Perfil_Penalizaciones}" FontSize="11" Foreground="#888888" Margin="0,4,0,0"/>
                            </StackPanel>
                        </Border>
                    </Grid>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</Page>