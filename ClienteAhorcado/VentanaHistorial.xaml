<Window x:Class="ClienteAhorcado.VentanaHistorial"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ClienteAhorcado"
        mc:Ignorable="d"
        Title="Ahorcado · Historial" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen" Background="#F0F0F0">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="White">
            <Border BorderBrush="#EEEEEE" BorderThickness="0,0,0,1">
                <Grid Margin="20,12,20,12">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                        <Button Content="⇐ Volver" Padding="10,5" Background="White" Foreground="Black" BorderBrush="#CCCCCC" BorderThickness="1" FontSize="13" Margin="0,0,15,0" Click="btnVolver_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="5"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                        <StackPanel>
                            <TextBlock Text="Historial de puntajes" FontSize="16" FontWeight="Bold"/>
                            <TextBlock Text="Tu progreso, partida por partida" FontSize="12" Foreground="#666666"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="🌐 ES" Padding="10,5" Background="White" Foreground="Black" BorderBrush="#CCCCCC" BorderThickness="1" FontSize="13" Margin="0,0,10,0">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="5"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                        <Button Content="Andrés ▼" Padding="10,5" Background="#333333" Foreground="White" BorderThickness="0" FontSize="13">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="20"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <StackPanel Grid.Row="1" Margin="20">
            <Border Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" Opacity="0.08" ShadowDepth="2"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="#0078D4" CornerRadius="8" Width="60" Height="60" Margin="0,0,20,0">
                        <TextBlock Text="🏆" FontSize="26" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="PUNTAJE GLOBAL" FontSize="11" Foreground="#888888" FontWeight="Bold"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="75" FontSize="36" FontWeight="Bold"/>
                            <TextBlock Text=" pts" FontSize="18" Foreground="#888888" VerticalAlignment="Bottom" Margin="0,0,0,5"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Grid.Column="2" HorizontalAlignment="Center" Margin="30,0">
                        <TextBlock Text="5" FontSize="28" FontWeight="Bold" Foreground="Green" HorizontalAlignment="Center"/>
                        <TextBlock Text="GANADAS" FontSize="11" Foreground="#888888" FontWeight="Bold"/>
                    </StackPanel>
                    <StackPanel Grid.Column="3" HorizontalAlignment="Center" Margin="30,0">
                        <TextBlock Text="3" FontSize="28" FontWeight="Bold" Foreground="#555555" HorizontalAlignment="Center"/>
                        <TextBlock Text="RIVAL NO ADIVINÓ" FontSize="11" Foreground="#888888" FontWeight="Bold"/>
                    </StackPanel>
                    <StackPanel Grid.Column="4" HorizontalAlignment="Center" Margin="30,0,0,0">
                        <TextBlock Text="2" FontSize="28" FontWeight="Bold" Foreground="Red" HorizontalAlignment="Center"/>
                        <TextBlock Text="PENALIZACIONES" FontSize="11" Foreground="#888888" FontWeight="Bold"/>
                    </StackPanel>
                </Grid>
            </Border>

            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                <Button x:Name="btnGanadas" Content="Partidas ganadas (5)" Padding="15,8" Background="#0078D4" Foreground="White" BorderThickness="0" FontSize="13" Margin="0,0,5,0" Click="btnGanadas_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <Button x:Name="btnRival" Content="Rival no adivinó (3)" Padding="15,8" Background="White" Foreground="#333333" BorderBrush="#CCCCCC" BorderThickness="1" FontSize="13" Margin="0,0,5,0" Click="btnRival_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <Button x:Name="btnPenalizaciones" Content="Penalizaciones (2)" Padding="15,8" Background="White" Foreground="#333333" BorderBrush="#CCCCCC" BorderThickness="1" FontSize="13" Click="btnPenalizaciones_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>

            <Border Background="White" CornerRadius="8">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" Opacity="0.08" ShadowDepth="2"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
                    <Grid Grid.Row="0" Background="#F9F9F9" Margin="0,0,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock x:Name="colFecha" Grid.Column="0" Text="FECHA" FontSize="12" FontWeight="Bold" Foreground="#666666" Margin="15,10,0,10"/>
                        <TextBlock x:Name="colPalabra" Grid.Column="1" Text="PALABRA ADIVINADA" FontSize="12" FontWeight="Bold" Foreground="#666666" Margin="10,10,0,10"/>
                        <TextBlock x:Name="colRival" Grid.Column="2" Text="RIVAL VENCIDO" FontSize="12" FontWeight="Bold" Foreground="#666666" Margin="10,10,0,10"/>
                        <TextBlock Grid.Column="3" Text="PUNTOS" FontSize="12" FontWeight="Bold" Foreground="#666666" Margin="10,10,15,10" HorizontalAlignment="Right"/>
                    </Grid>
                    <ListView x:Name="lvHistorial" Grid.Row="1" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="BorderBrush" Value="#EEEEEE"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListViewItem>
                            <Grid Margin="0,10,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="24 may 2026" FontSize="13" Foreground="#555555" Margin="15,0,0,0"/>
                                <TextBlock Grid.Column="1" Text="ELEFANTE" FontSize="13" FontWeight="Bold" Margin="10,0,0,0"/>
                                <TextBlock Grid.Column="2" Text="Carlos Mendoza" FontSize="13" Foreground="#555555" Margin="10,0,0,0"/>
                                <TextBlock x:Name="lblPuntos1" Grid.Column="3" Text="+10 pts" FontSize="13" FontWeight="Bold" Foreground="Green" Margin="10,0,15,0" HorizontalAlignment="Right"/>
                            </Grid>
                        </ListViewItem>
                        <ListViewItem>
                            <Grid Margin="0,10,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="22 may 2026" FontSize="13" Foreground="#555555" Margin="15,0,0,0"/>
                                <TextBlock Grid.Column="1" Text="JIRAFA" FontSize="13" FontWeight="Bold" Margin="10,0,0,0"/>
                                <TextBlock Grid.Column="2" Text="Sofía Ramírez" FontSize="13" Foreground="#555555" Margin="10,0,0,0"/>
                                <TextBlock Grid.Column="3" Text="+10 pts" FontSize="13" FontWeight="Bold" Foreground="Green" Margin="10,0,15,0" HorizontalAlignment="Right"/>
                            </Grid>
                        </ListViewItem>
                        <ListViewItem>
                            <Grid Margin="0,10,0,10">
                                <Grid.ColumnDefinitions>
                                    <ColumnDefinition Width="1.5*"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="2*"/>
                                    <ColumnDefinition Width="1*"/>
                                </Grid.ColumnDefinitions>
                                <TextBlock Grid.Column="0" Text="20 may 2026" FontSize="13" Foreground="#555555" Margin="15,0,0,0"/>
                                <TextBlock Grid.Column="1" Text="PARIS" FontSize="13" FontWeight="Bold" Margin="10,0,0,0"/>
                                <TextBlock Grid.Column="2" Text="Diego Hernández" FontSize="13" Foreground="#555555" Margin="10,0,0,0"/>
                                <TextBlock Grid.Column="3" Text="+10 pts" FontSize="13" FontWeight="Bold" Foreground="Green" Margin="10,0,15,0" HorizontalAlignment="Right"/>
                            </Grid>
                        </ListViewItem>
                    </ListView>
                </Grid>
            </Border>
        </StackPanel>
    </Grid>
</Window>