<Window x:Class="ClienteAhorcado.VentanaHistorial"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ClienteAhorcado"
        xmlns:p="clr-namespace:ClienteAhorcado.Properties"
        mc:Ignorable="d"
        Title="{x:Static p:Resources.Historial_TituloVentana}" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen" Background="#F0F0F0">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>

        <Grid Grid.Row="0" Background="White">
            <Border BorderBrush="#EEEEEE" BorderThickness="0,0,0,1">
                <Grid Margin="20,12,20,12">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                        <Button Content="{x:Static p:Resources.Comun_Volver}" Padding="10,5" Background="White" Foreground="Black" BorderBrush="#CCCCCC" BorderThickness="1" FontSize="13" Margin="0,0,15,0" Click="btnVolver_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="5"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                        <StackPanel>
                            <TextBlock Text="{x:Static p:Resources.Historial_Titulo}" FontSize="16" FontWeight="Bold"/>
                            <TextBlock Text="{x:Static p:Resources.Historial_Subtitulo}" FontSize="12" Foreground="#666666"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button x:Name="btnIdioma" Content="🌐 ES" Padding="10,5" Background="White" Foreground="Black" BorderBrush="#CCCCCC" BorderThickness="1" FontSize="13" Margin="0,0,10,0" Click="btnIdioma_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="5"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                        <Button x:Name="btnUsuario" Content="Usuario ▼" Padding="10,5" Background="#333333" Foreground="White" BorderThickness="0" FontSize="13">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="20"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>

        <StackPanel Grid.Row="1" Margin="20">
           
            <Border Background="White" CornerRadius="8" Padding="20" Margin="0,0,0,15">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" Opacity="0.08" ShadowDepth="2"/>
                </Border.Effect>
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="Auto"/>
                    </Grid.ColumnDefinitions>
                    <Border Grid.Column="0" Background="#0078D4" CornerRadius="8" Width="60" Height="60" Margin="0,0,20,0">
                        <TextBlock Text="🏆" FontSize="26" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <StackPanel Grid.Column="1" VerticalAlignment="Center">
                        <TextBlock Text="{x:Static p:Resources.Historial_PuntajeGlobalEtiqueta}" FontSize="11" Foreground="#888888" FontWeight="Bold"/>
                        <StackPanel Orientation="Horizontal">
                            <TextBlock x:Name="txtPuntajeGlobal" Text="0" FontSize="36" FontWeight="Bold"/>
                            <TextBlock Text="{x:Static p:Resources.Historial_PtsSufijo}" FontSize="18" Foreground="#888888" VerticalAlignment="Bottom" Margin="0,0,0,5"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Grid.Column="2" HorizontalAlignment="Center" Margin="30,0">
                        <TextBlock x:Name="txtGanadas" Text="0" FontSize="28" FontWeight="Bold" Foreground="Green" HorizontalAlignment="Center"/>
                        <TextBlock Text="{x:Static p:Resources.Historial_Ganadas}" FontSize="11" Foreground="#888888" FontWeight="Bold"/>
                    </StackPanel>
                    <StackPanel Grid.Column="3" HorizontalAlignment="Center" Margin="30,0">
                        <TextBlock x:Name="txtRivalNoPudo" Text="0" FontSize="28" FontWeight="Bold" Foreground="#555555" HorizontalAlignment="Center"/>
                        <TextBlock Text="{x:Static p:Resources.Historial_RivalNoAdivino}" FontSize="11" Foreground="#888888" FontWeight="Bold"/>
                    </StackPanel>
                    <StackPanel Grid.Column="4" HorizontalAlignment="Center" Margin="30,0,0,0">
                        <TextBlock x:Name="txtPenalizaciones" Text="0" FontSize="28" FontWeight="Bold" Foreground="Red" HorizontalAlignment="Center"/>
                        <TextBlock Text="{x:Static p:Resources.Historial_Penalizaciones}" FontSize="11" Foreground="#888888" FontWeight="Bold"/>
                    </StackPanel>
                </Grid>
            </Border>

           
            <StackPanel Orientation="Horizontal" Margin="0,0,0,15">
                <Button x:Name="btnGanadas" Content="" Padding="15,8" Background="#0078D4" Foreground="White" BorderThickness="0" FontSize="13" Margin="0,0,5,0" Click="btnGanadas_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <Button x:Name="btnRival" Content="" Padding="15,8" Background="White" Foreground="#333333" BorderBrush="#CCCCCC" BorderThickness="1" FontSize="13" Margin="0,0,5,0" Click="btnRival_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
                <Button x:Name="btnPenalizaciones" Content="" Padding="15,8" Background="White" Foreground="#333333" BorderBrush="#CCCCCC" BorderThickness="1" FontSize="13" Click="btnPenalizaciones_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>
            </StackPanel>

            <!-- Tabla de historial -->
            <Border Background="White" CornerRadius="8">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" Opacity="0.08" ShadowDepth="2"/>
                </Border.Effect>
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                    </Grid.RowDefinitions>
              
                    <Grid Grid.Row="0" Background="#F9F9F9">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="1.5*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="2*"/>
                            <ColumnDefinition Width="1*"/>
                        </Grid.ColumnDefinitions>
                        <TextBlock Grid.Column="0" Text="{x:Static p:Resources.Historial_ColFecha}" FontSize="12" FontWeight="Bold" Foreground="#666666" Margin="15,10,0,10"/>
                        <TextBlock x:Name="colPalabra" Grid.Column="1" Text="PALABRA ADIVINADA" FontSize="12" FontWeight="Bold" Foreground="#666666" Margin="10,10,0,10"/>
                        <TextBlock x:Name="colRival" Grid.Column="2" Text="RIVAL VENCIDO" FontSize="12" FontWeight="Bold" Foreground="#666666" Margin="10,10,0,10"/>
                        <TextBlock Grid.Column="3" Text="{x:Static p:Resources.Historial_ColPuntos}" FontSize="12" FontWeight="Bold" Foreground="#666666" Margin="10,10,15,10" HorizontalAlignment="Right"/>
                    </Grid>
                
                    <ListView x:Name="lvHistorial" Grid.Row="1" BorderThickness="0" ScrollViewer.HorizontalScrollBarVisibility="Disabled">
                        <ListView.ItemContainerStyle>
                            <Style TargetType="ListViewItem">
                                <Setter Property="HorizontalContentAlignment" Value="Stretch"/>
                                <Setter Property="Padding" Value="0"/>
                                <Setter Property="BorderBrush" Value="#EEEEEE"/>
                                <Setter Property="BorderThickness" Value="0,0,0,1"/>
                            </Style>
                        </ListView.ItemContainerStyle>
                        <ListView.ItemTemplate>
                            <DataTemplate>
                                <Grid Margin="0,10,0,10">
                                    <Grid.ColumnDefinitions>
                                        <ColumnDefinition Width="1.5*"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="2*"/>
                                        <ColumnDefinition Width="1*"/>
                                    </Grid.ColumnDefinitions>
                                    <TextBlock Grid.Column="0" Text="{Binding Fecha}"   FontSize="13" Foreground="#555555" Margin="15,0,0,0" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="1" Text="{Binding Palabra}" FontSize="13" FontWeight="Bold"    Margin="10,0,0,0" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="2" Text="{Binding Rival}"   FontSize="13" Foreground="#555555" Margin="10,0,0,0" VerticalAlignment="Center"/>
                                    <TextBlock Grid.Column="3" Text="{Binding Puntos}"  FontSize="13" FontWeight="Bold"
                                               Foreground="{Binding Color}" Margin="10,0,15,0"
                                               HorizontalAlignment="Right" VerticalAlignment="Center"/>
                                </Grid>
                            </DataTemplate>
                        </ListView.ItemTemplate>
                    </ListView>
                </Grid>
            </Border>
        </StackPanel>
    </Grid>
</Window>
