<?xml version="1.0" encoding="utf-8" ?>
<configuration>
    <startup>
        <supportedRuntime version="v4.0" sku=".NETFramework,Version=v4.7.2" />
    </startup>
    <system.serviceModel>
        <bindings>
            <!-- TCP/IP. SecurityMode None debe coincidir con el host del servidor. -->
            <netTcpBinding>
                <binding name="TcpAhorcado">
                    <security mode="None" />
                </binding>
            </netTcpBinding>
        </bindings>
        <client>
            <!-- NOTA: reemplace SERVIDOR_IP por la IP (o nombre) de la maquina servidor
                 en la red local, y el puerto si lo cambian en el host (por defecto 8000). -->
            <endpoint name="AutenticacionEndpoint"
                      address="net.tcp://SERVIDOR_IP:8000/AutenticacionService"
                      binding="netTcpBinding" bindingConfiguration="TcpAhorcado"
                      contract="AhorcadoWCF.IAutenticacionService" />
            <endpoint name="UsuarioEndpoint"
                      address="net.tcp://SERVIDOR_IP:8000/UsuarioService"
                      binding="netTcpBinding" bindingConfiguration="TcpAhorcado"
                      contract="AhorcadoWCF.IUsuarioService" />
            <endpoint name="PartidaEndpoint"
                      address="net.tcp://SERVIDOR_IP:8000/PartidaService"
                      binding="netTcpBinding" bindingConfiguration="TcpAhorcado"
                      contract="AhorcadoWCF.IPartidaService" />
            <endpoint name="PuntajeEndpoint"
                      address="net.tcp://SERVIDOR_IP:8000/PuntajeService"
                      binding="netTcpBinding" bindingConfiguration="TcpAhorcado"
                      contract="AhorcadoWCF.IPuntajeService" />
            <endpoint name="PalabraEndpoint"
                      address="net.tcp://SERVIDOR_IP:8000/PalabraService"
                      binding="netTcpBinding" bindingConfiguration="TcpAhorcado"
                      contract="AhorcadoWCF.IPalabraService" />
            <endpoint name="MovimientoEndpoint"
                      address="net.tcp://SERVIDOR_IP:8000/MovimientoService"
                      binding="netTcpBinding" bindingConfiguration="TcpAhorcado"
                      contract="AhorcadoWCF.IMovimientoService" />
            <endpoint name="JuegoEndpoint"
                      address="net.tcp://SERVIDOR_IP:8000/JuegoCallbackService"
                      binding="netTcpBinding" bindingConfiguration="TcpAhorcado"
                      contract="AhorcadoWCF.IJuegoCallbackService" />
        </client>
    </system.serviceModel>
</configuration>