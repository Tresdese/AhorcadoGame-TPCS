<Window x:Class="ClienteAhorcado.VentanaElegirCategoria"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ClienteAhorcado"
        mc:Ignorable="d"
        Title="Ahorcado · Elegir categoría" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen" Background="#F0F0F0">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Background="White">
            <Border BorderBrush="#EEEEEE" BorderThickness="0,0,0,1">
                <Grid Margin="20,12,20,12">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                        <Button Content="⇐ Volver" Padding="10,5" Background="White" Foreground="Black" BorderBrush="#CCCCCC" BorderThickness="1" FontSize="13" Margin="0,0,15,0" Click="btnVolver_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="5"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                        <TextBlock Text="Paso 1 de 2 · Elige una categoría" FontSize="16" FontWeight="Bold" VerticalAlignment="Center"/>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="🌐 ES" Padding="10,5" Background="White" Foreground="Black" BorderBrush="#CCCCCC" BorderThickness="1" FontSize="13" Margin="0,0,10,0">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="5"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                        <Button Content="Andrés ▼" Padding="10,5" Background="#333333" Foreground="White" BorderThickness="0" FontSize="13">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="20"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
        <Grid Grid.Row="1" Margin="20">
            <Grid.RowDefinitions>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>
            <UniformGrid Grid.Row="0" Columns="3" Rows="2">
                <Border x:Name="btnAnimales" Background="#0078D4" CornerRadius="8" Margin="5" Cursor="Hand" MouseLeftButtonUp="btnAnimales_Click">
                    <StackPanel Margin="20">
                        <TextBlock Text="Animales" FontSize="20" FontWeight="Bold" Foreground="White"/>
                        <TextBlock Text="24 palabras" FontSize="13" Foreground="#CCDDFF" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
                <Border x:Name="btnPaises" Background="White" CornerRadius="8" Margin="5" Cursor="Hand" MouseLeftButtonUp="btnPaises_Click">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" Opacity="0.08" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel Margin="20">
                        <TextBlock Text="Países" FontSize="20" FontWeight="Bold"/>
                        <TextBlock Text="32 palabras" FontSize="13" Foreground="#888888" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
                <Border x:Name="btnComida" Background="White" CornerRadius="8" Margin="5" Cursor="Hand" MouseLeftButtonUp="btnComida_Click">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" Opacity="0.08" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel Margin="20">
                        <TextBlock Text="Comida" FontSize="20" FontWeight="Bold"/>
                        <TextBlock Text="28 palabras" FontSize="13" Foreground="#888888" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
                <Border x:Name="btnDeportes" Background="White" CornerRadius="8" Margin="5" Cursor="Hand" MouseLeftButtonUp="btnDeportes_Click">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" Opacity="0.08" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel Margin="20">
                        <TextBlock Text="Deportes" FontSize="20" FontWeight="Bold"/>
                        <TextBlock Text="18 palabras" FontSize="13" Foreground="#888888" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
                <Border x:Name="btnPeliculas" Background="White" CornerRadius="8" Margin="5" Cursor="Hand" MouseLeftButtonUp="btnPeliculas_Click">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" Opacity="0.08" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel Margin="20">
                        <TextBlock Text="Películas" FontSize="20" FontWeight="Bold"/>
                        <TextBlock Text="21 palabras" FontSize="13" Foreground="#888888" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
                <Border x:Name="btnTecnologia" Background="White" CornerRadius="8" Margin="5" Cursor="Hand" MouseLeftButtonUp="btnTecnologia_Click">
                    <Border.Effect>
                        <DropShadowEffect BlurRadius="8" Opacity="0.08" ShadowDepth="2"/>
                    </Border.Effect>
                    <StackPanel Margin="20">
                        <TextBlock Text="Tecnología" FontSize="20" FontWeight="Bold"/>
                        <TextBlock Text="16 palabras" FontSize="13" Foreground="#888888" Margin="0,5,0,0"/>
                    </StackPanel>
                </Border>
            </UniformGrid>
            <Button Grid.Row="1" Content="Continuar ⇒" HorizontalAlignment="Right" Padding="20,10" Background="#0078D4" Foreground="White" BorderThickness="0" FontSize="14" FontWeight="Bold" Margin="0,15,0,0" Click="btnContinuar_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>
        </Grid>
    </Grid>
</Window>