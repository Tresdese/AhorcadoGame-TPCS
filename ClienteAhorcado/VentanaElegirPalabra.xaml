<Window x:Class="ClienteAhorcado.VentanaElegirPalabra"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ClienteAhorcado"
        mc:Ignorable="d"
        Title="Ahorcado · Elegir palabra" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen" Background="#F0F0F0">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
            <RowDefinition Height="Auto"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Background="White">
            <Border BorderBrush="#EEEEEE" BorderThickness="0,0,0,1">
                <Grid Margin="20,12,20,12">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                        <Button Content="⇐ Volver" Padding="10,5" Background="White" Foreground="Black" BorderBrush="#CCCCCC" BorderThickness="1" FontSize="13" Margin="0,0,15,0" Click="btnVolver_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="5"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                        <StackPanel>
                            <TextBlock Text="Paso 2 de 2 · Elige una palabra" FontSize="16" FontWeight="Bold"/>
                            <TextBlock Text="Categoría: Animales" FontSize="12" Foreground="#666666"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button Content="🌐 ES" Padding="10,5" Background="White" Foreground="Black" BorderBrush="#CCCCCC" BorderThickness="1" FontSize="13" Margin="0,0,10,0">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="5"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                        <Button Content="Andrés ▼" Padding="10,5" Background="#333333" Foreground="White" BorderThickness="0" FontSize="13">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="20"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
        <StackPanel Grid.Row="1" Margin="20,15,20,0">
            <TextBlock Text="8 PALABRAS DISPONIBLES" FontSize="12" FontWeight="Bold" Foreground="#888888" Margin="0,0,0,10"/>
            <Border Background="White" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="8">
                <StackPanel>
                    <Border BorderBrush="#0078D4" BorderThickness="2" CornerRadius="7" Background="#F0F7FF" Margin="1">
                        <Grid Margin="15,12">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="20" Height="20" Fill="#0078D4" Margin="0,0,10,0"/>
                                <TextBlock Text="ELEFANTE" FontSize="14" FontWeight="Bold" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="8 letras" FontSize="13" Foreground="#888888" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <Border BorderBrush="#EEEEEE" BorderThickness="0,1,0,0">
                        <Grid Margin="15,12">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="20" Height="20" Stroke="#CCCCCC" StrokeThickness="1.5" Margin="0,0,10,0"/>
                                <TextBlock Text="JIRAFA" FontSize="14" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="6 letras" FontSize="13" Foreground="#888888" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <Border BorderBrush="#EEEEEE" BorderThickness="0,1,0,0">
                        <Grid Margin="15,12">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="20" Height="20" Stroke="#CCCCCC" StrokeThickness="1.5" Margin="0,0,10,0"/>
                                <TextBlock Text="TORTUGA" FontSize="14" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="7 letras" FontSize="13" Foreground="#888888" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <Border BorderBrush="#EEEEEE" BorderThickness="0,1,0,0">
                        <Grid Margin="15,12">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="20" Height="20" Stroke="#CCCCCC" StrokeThickness="1.5" Margin="0,0,10,0"/>
                                <TextBlock Text="PINGÜINO" FontSize="14" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="8 letras" FontSize="13" Foreground="#888888" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <Border BorderBrush="#EEEEEE" BorderThickness="0,1,0,0">
                        <Grid Margin="15,12">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="20" Height="20" Stroke="#CCCCCC" StrokeThickness="1.5" Margin="0,0,10,0"/>
                                <TextBlock Text="COCODRILO" FontSize="14" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="9 letras" FontSize="13" Foreground="#888888" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <Border BorderBrush="#EEEEEE" BorderThickness="0,1,0,0">
                        <Grid Margin="15,12">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="20" Height="20" Stroke="#CCCCCC" StrokeThickness="1.5" Margin="0,0,10,0"/>
                                <TextBlock Text="MARIPOSA" FontSize="14" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="8 letras" FontSize="13" Foreground="#888888" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <Border BorderBrush="#EEEEEE" BorderThickness="0,1,0,0">
                        <Grid Margin="15,12">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="20" Height="20" Stroke="#CCCCCC" StrokeThickness="1.5" Margin="0,0,10,0"/>
                                <TextBlock Text="CABALLO" FontSize="14" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="7 letras" FontSize="13" Foreground="#888888" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                    <Border BorderBrush="#EEEEEE" BorderThickness="0,1,0,0">
                        <Grid Margin="15,12">
                            <StackPanel Orientation="Horizontal">
                                <Ellipse Width="20" Height="20" Stroke="#CCCCCC" StrokeThickness="1.5" Margin="0,0,10,0"/>
                                <TextBlock Text="TIBURÓN" FontSize="14" VerticalAlignment="Center"/>
                            </StackPanel>
                            <TextBlock Text="7 letras" FontSize="13" Foreground="#888888" HorizontalAlignment="Right" VerticalAlignment="Center"/>
                        </Grid>
                    </Border>
                </StackPanel>
            </Border>
        </StackPanel>
        <StackPanel Grid.Row="2" Orientation="Horizontal" HorizontalAlignment="Right" Margin="20,15,20,20">
            <Button Content="Cancelar" Padding="15,8" Background="White" Foreground="#333333" BorderBrush="#CCCCCC" BorderThickness="1" FontSize="14" Margin="0,0,10,0" Click="btnCancelar_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>
            <Button Content="Confirmar palabra" Padding="15,8" Background="#0078D4" Foreground="White" BorderThickness="0" FontSize="14" FontWeight="Bold" Click="btnConfirmar_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Grid>
</Window>