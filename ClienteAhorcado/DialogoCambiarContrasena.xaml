<Window x:Class="ClienteAhorcado.DialogoCambiarContrasena"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:local="clr-namespace:ClienteAhorcado"
        xmlns:p="clr-namespace:ClienteAhorcado.Properties"
        Title="" Width="450" SizeToContent="Height"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" WindowStyle="None"
        Background="Transparent" AllowsTransparency="True">
    <Border Background="White" CornerRadius="10" Padding="30">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Opacity="0.2" ShadowDepth="5"/>
        </Border.Effect>
        <StackPanel>
            <TextBlock Text="{x:Static p:Resources.CambiarContrasena_Titulo}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,20"/>

            <StackPanel x:Name="panelPaso1">
                <TextBlock Text="{x:Static p:Resources.CambiarContrasena_Paso1}" FontSize="13" Foreground="#555555" TextWrapping="Wrap" Margin="0,0,0,15"/>
                <TextBlock Text="{x:Static p:Resources.CambiarContrasena_ContrasenaActual}" FontSize="13" Foreground="#333333" Margin="0,0,0,5"/>
                <local:CampoContrasena x:Name="txtActual"/>
                <TextBlock x:Name="lblErrorActual" Foreground="Red" FontSize="12" Visibility="Collapsed" TextWrapping="Wrap" Margin="0,4,0,0"/>
                <Grid Margin="0,20,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="{x:Static p:Resources.Comun_Cancelar}" Height="40" Background="White" Foreground="#333333" BorderBrush="#CCCCCC" BorderThickness="1" FontSize="13" Click="btnCancelar_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button Grid.Column="2" Content="{x:Static p:Resources.Comun_Continuar}" Height="40" Background="#0078D4" Foreground="White" BorderThickness="0" FontSize="13" FontWeight="Bold" Click="btnContinuar_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>
            </StackPanel>

            <StackPanel x:Name="panelPaso2" Visibility="Collapsed">
                <TextBlock Text="{x:Static p:Resources.CambiarContrasena_Paso2}" FontSize="13" Foreground="#555555" TextWrapping="Wrap" Margin="0,0,0,15"/>
                <TextBlock Text="{x:Static p:Resources.CambiarContrasena_NuevaContrasena}" FontSize="13" Foreground="#333333" Margin="0,0,0,5"/>
                <local:CampoContrasena x:Name="txtNueva" PasswordChanged="txtNueva_PasswordChanged"/>
                <TextBlock Text="{x:Static p:Resources.RegistrarCuenta_ConfirmarContrasena}" FontSize="13" Foreground="#333333" Margin="0,12,0,5"/>
                <local:CampoContrasena x:Name="txtConfirmar"/>
                <TextBlock x:Name="lblErrorNueva" Foreground="Red" FontSize="12" Visibility="Collapsed" TextWrapping="Wrap" Margin="0,4,0,0"/>

                <Border Background="#F5F5F5" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="5" Padding="15" Margin="0,15,0,0">
                    <StackPanel>
                        <TextBlock Text="{x:Static p:Resources.RegistrarCuenta_RequisitosTitulo}" FontSize="12" FontWeight="Bold" Foreground="#333333" Margin="0,0,0,8"/>
                        <WrapPanel>
                            <CheckBox x:Name="chk8Caracteres" Content="{x:Static p:Resources.RegistrarCuenta_Req8}" FontSize="12" IsEnabled="False" Margin="0,0,20,4"/>
                            <CheckBox x:Name="chkMayuscula" Content="{x:Static p:Resources.RegistrarCuenta_ReqMayuscula}" FontSize="12" IsEnabled="False" Margin="0,0,20,4"/>
                            <CheckBox x:Name="chkMinuscula" Content="{x:Static p:Resources.RegistrarCuenta_ReqMinuscula}" FontSize="12" IsEnabled="False" Margin="0,0,20,4"/>
                            <CheckBox x:Name="chkNumero" Content="{x:Static p:Resources.RegistrarCuenta_ReqNumero}" FontSize="12" IsEnabled="False"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Grid Margin="0,20,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="10"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <Button Grid.Column="0" Content="{x:Static p:Resources.Comun_Cancelar}" Height="40" Background="White" Foreground="#333333" BorderBrush="#CCCCCC" BorderThickness="1" FontSize="13" Click="btnCancelar_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button Grid.Column="2" Content="{x:Static p:Resources.Comun_Guardar}" Height="40" Background="#0078D4" Foreground="White" BorderThickness="0" FontSize="13" FontWeight="Bold" Click="btnGuardar_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                </Grid>
            </StackPanel>
        </StackPanel>
    </Border>
</Window>