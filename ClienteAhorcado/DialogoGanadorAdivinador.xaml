<Window x:Class="ClienteAhorcado.DialogoGanadorAdivinador"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ClienteAhorcado"
        xmlns:p="clr-namespace:ClienteAhorcado.Properties"
        mc:Ignorable="d"
        Title="" Height="480" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" WindowStyle="None"
        Background="Transparent" AllowsTransparency="True">
    <Border Background="White" CornerRadius="10" Padding="30">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Opacity="0.2" ShadowDepth="5"/>
        </Border.Effect>
        <StackPanel>
            <Border Background="#E8F5E9" CornerRadius="8" Width="55" Height="55" HorizontalAlignment="Center" Margin="0,0,0,15">
                <TextBlock Text="🏆" FontSize="26" HorizontalAlignment="Center" VerticalAlignment="Center"/>
            </Border>
            <TextBlock Text="{x:Static p:Resources.GanadorAdivinador_Titulo}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
            <TextBlock Text="{x:Static p:Resources.GanadorAdivinador_Subtitulo}" FontSize="13" Foreground="#555555" HorizontalAlignment="Center" Margin="0,0,0,15"/>
            <Border Background="#F9F9F9" BorderBrush="#EEEEEE" BorderThickness="1" CornerRadius="5" Padding="15,10" Margin="0,0,0,20">
                <StackPanel>
                    <Grid Margin="0,0,0,8">
                        <TextBlock Text="{x:Static p:Resources.Comun_Palabra}" FontSize="13" Foreground="#888888" HorizontalAlignment="Left"/>
                        <TextBlock x:Name="txtPalabra" Text="" FontSize="13" FontWeight="Bold" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <TextBlock Text="{x:Static p:Resources.Comun_Rival}" FontSize="13" Foreground="#888888" HorizontalAlignment="Left"/>
                        <TextBlock x:Name="txtRival" Text="" FontSize="13" FontWeight="Bold" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid Margin="0,0,0,15">
                        <TextBlock Text="{x:Static p:Resources.Comun_Categoria}" FontSize="13" Foreground="#888888" HorizontalAlignment="Left"/>
                        <TextBlock x:Name="txtCategoria" Text="" FontSize="13" FontWeight="Bold" HorizontalAlignment="Right"/>
                    </Grid>
                    <Border BorderBrush="#EEEEEE" BorderThickness="0,1,0,0" Padding="0,10,0,0">
                        <StackPanel>
                            <Grid Margin="0,0,0,5">
                                <TextBlock Text="{x:Static p:Resources.Comun_PuntosObtenidos}" FontSize="13" Foreground="#888888" HorizontalAlignment="Left"/>
                                <TextBlock x:Name="txtPuntosObtenidos" Text="" FontSize="13" FontWeight="Bold" Foreground="Green" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid>
                                <TextBlock Text="{x:Static p:Resources.Comun_PuntajeGlobal}" FontSize="13" Foreground="#888888" HorizontalAlignment="Left"/>
                                <TextBlock x:Name="txtPuntajeGlobal" Text="" FontSize="13" FontWeight="Bold" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
            <TextBlock FontSize="13" Foreground="#555555" HorizontalAlignment="Center" Margin="0,0,0,15">
                <Run Text="{x:Static p:Resources.DialogoResultado_PreguntaPrefijo}"/>
                <Run x:Name="txtPreguntaRival" Text="" FontWeight="Bold"/>
                <Run Text="{x:Static p:Resources.DialogoResultado_PreguntaSufijo}"/>
            </TextBlock>
            <Button Content="{x:Static p:Resources.Comun_IrAlLobby}" Height="40" Background="#0078D4" Foreground="White" BorderThickness="0" FontSize="13" FontWeight="Bold" Click="btnLobby_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Border>
</Window>
