<Window x:Class="ClienteAhorcado.DialogoPenalizacion"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ClienteAhorcado"
        xmlns:p="clr-namespace:ClienteAhorcado.Properties"
        mc:Ignorable="d"
        Title="" Height="360" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" WindowStyle="None"
        Background="Transparent" AllowsTransparency="True">
    <Border Background="White" CornerRadius="10" Padding="30">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Opacity="0.2" ShadowDepth="5"/>
        </Border.Effect>
        <StackPanel>
            <Border Background="#FFEBEE" CornerRadius="8" Width="55" Height="55" HorizontalAlignment="Center" Margin="0,0,0,15">
                <TextBlock Text="⊖" FontSize="26" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#D32F2F"/>
            </Border>
            <TextBlock Text="{x:Static p:Resources.Penalizacion_Titulo}" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,8"/>
            <TextBlock Text="{x:Static p:Resources.Penalizacion_Mensaje}" FontSize="13" Foreground="#555555" TextAlignment="Center" TextWrapping="Wrap" Margin="0,0,0,15"/>
            <TextBlock x:Name="txtResta" Text="" FontSize="36" FontWeight="Bold" Foreground="#D32F2F" HorizontalAlignment="Center" Margin="0,0,0,15"/>
            <Border Background="#F9F9F9" BorderBrush="#EEEEEE" BorderThickness="1" CornerRadius="5" Padding="15,10" Margin="0,0,0,20">
                <Grid>
                    <TextBlock Text="{x:Static p:Resources.Penalizacion_PuntajeAnterior}" FontSize="13" Foreground="#888888" HorizontalAlignment="Left"/>
                    <TextBlock x:Name="txtPuntaje" Text="" FontSize="13" FontWeight="Bold" HorizontalAlignment="Right"/>
                </Grid>
            </Border>
            <Button Content="{x:Static p:Resources.Comun_Aceptar}" Height="40" Background="#0078D4" Foreground="White" BorderThickness="0" FontSize="14" FontWeight="Bold" Click="btnAceptar_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Border>
</Window>
