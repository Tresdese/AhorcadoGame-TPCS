<Window x:Class="ClienteAhorcado.VentanaJuegoCreador"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ClienteAhorcado"
        mc:Ignorable="d"
        Title="Ahorcado · Partida en curso" Height="650" Width="1000"
        WindowStartupLocation="CenterScreen" Background="#F0F0F0">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Background="White" Margin="0,0,0,1">
                <Border BorderBrush="#EEEEEE" BorderThickness="0,0,0,1">
                    <Grid Margin="15,10,15,10">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                            <Border Width="36" Height="36" CornerRadius="18" Background="#555555" Margin="0,0,10,0">
                                <TextBlock Text="AS" FontSize="13" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Tú (creador)" FontSize="14" FontWeight="Bold"/>
                                <TextBlock Text="vs Carlos Mendoza" FontSize="12" Foreground="#666666"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Border BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="5" Padding="12,6" Margin="0,0,10,0">
                                <TextBlock Text="3  intentos restantes" FontSize="13" FontWeight="Bold"/>
                            </Border>
                            <Button Content="Abandonar partida" Padding="12,6" Background="#D32F2F" Foreground="White" BorderThickness="0" FontSize="13" FontWeight="Bold" Click="btnAbandonar_Click">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="5"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="1" Background="White" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="5" Margin="15,10,15,0" Padding="15,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,30,0">
                        <TextBlock Text="CATEGORÍA" FontSize="11" FontWeight="Bold" Foreground="#888888"/>
                        <TextBlock Text="Animales" FontSize="14" FontWeight="Bold" Margin="0,4,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="DESCRIPCIÓN" FontSize="11" FontWeight="Bold" Foreground="#888888"/>
                        <TextBlock Text="Mamífero terrestre más grande, con trompa y orejas grandes." FontSize="14" TextWrapping="Wrap" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Border Grid.Row="2" Margin="15,10,15,0" Background="White" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="5" Padding="12,8">
                <StackPanel Orientation="Horizontal">
                    <TextBlock Text="TU PALABRA:  " FontSize="13" FontWeight="Bold" Foreground="#888888" VerticalAlignment="Center"/>
                    <TextBlock Text="ELEFANTE" FontSize="16" FontWeight="Bold" Foreground="#0078D4" VerticalAlignment="Center"/>
                </StackPanel>
            </Border>

            <Image Grid.Row="3" Source="/Recursos/ahorcado_3.png" Width="180" Height="180" HorizontalAlignment="Center" VerticalAlignment="Center"/>

            <StackPanel Grid.Row="4" Margin="15,5,15,15">
                <WrapPanel HorizontalAlignment="Center" Margin="0,0,0,8">
                    <Border BorderBrush="#333333" BorderThickness="0,0,0,2" Width="45" Height="55" Margin="3">
                        <TextBlock Text="E" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border BorderBrush="#333333" BorderThickness="0,0,0,2" Width="45" Height="55" Margin="3"/>
                    <Border BorderBrush="#333333" BorderThickness="0,0,0,2" Width="45" Height="55" Margin="3">
                        <TextBlock Text="E" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border BorderBrush="#333333" BorderThickness="0,0,0,2" Width="45" Height="55" Margin="3"/>
                    <Border BorderBrush="#333333" BorderThickness="0,0,0,2" Width="45" Height="55" Margin="3"/>
                    <Border BorderBrush="#333333" BorderThickness="0,0,0,2" Width="45" Height="55" Margin="3"/>
                    <Border BorderBrush="#333333" BorderThickness="0,0,0,2" Width="45" Height="55" Margin="3">
                        <TextBlock Text="T" FontSize="22" FontWeight="Bold" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                    </Border>
                    <Border BorderBrush="#333333" BorderThickness="0,0,0,2" Width="45" Height="55" Margin="3"/>
                </WrapPanel>
                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center">
                    <TextBlock Text="LETRAS INCORRECTAS:  " FontSize="12" FontWeight="Bold" Foreground="#888888" VerticalAlignment="Center"/>
                    <Border BorderBrush="Red" BorderThickness="1" CornerRadius="3" Padding="8,4" Margin="3,0">
                        <TextBlock Text="R" FontSize="13" FontWeight="Bold" Foreground="Red"/>
                    </Border>
                    <Border BorderBrush="Red" BorderThickness="1" CornerRadius="3" Padding="8,4" Margin="3,0" Background="#FFEBEE">
                        <TextBlock Text="M" FontSize="13" FontWeight="Bold" Foreground="Red"/>
                    </Border>
                    <Border BorderBrush="Red" BorderThickness="1" CornerRadius="3" Padding="8,4" Margin="3,0">
                        <TextBlock Text="O" FontSize="13" FontWeight="Bold" Foreground="Red"/>
                    </Border>
                </StackPanel>
            </StackPanel>
        </Grid>

        <Grid Grid.Column="1" Background="White">
            <Border BorderBrush="#EEEEEE" BorderThickness="1,0,0,0">
                <Grid>
                    <Grid.RowDefinitions>
                        <RowDefinition Height="Auto"/>
                        <RowDefinition Height="*"/>
                        <RowDefinition Height="Auto"/>
                    </Grid.RowDefinitions>
                    <Border Grid.Row="0" BorderBrush="#EEEEEE" BorderThickness="0,0,0,1" Padding="15,12">
                        <StackPanel Orientation="Horizontal">
                            <TextBlock Text="💬  Chat" FontSize="15" FontWeight="Bold" VerticalAlignment="Center"/>
                            <Ellipse Width="8" Height="8" Fill="Green" Margin="8,0,0,0" VerticalAlignment="Center"/>
                        </StackPanel>
                    </Border>
                    <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Padding="10">
                        <StackPanel>
                            <Border Background="#0078D4" CornerRadius="8" Padding="10" Margin="50,0,0,8" HorizontalAlignment="Right">
                                <TextBlock Text="Hola Carlos 👋" FontSize="13" Foreground="White" TextWrapping="Wrap"/>
                            </Border>
                            <Border Background="#F0F0F0" CornerRadius="8" Padding="10" Margin="0,0,50,8" HorizontalAlignment="Left">
                                <StackPanel>
                                    <TextBlock Text="Carlos" FontSize="11" FontWeight="Bold" Foreground="#555555" Margin="0,0,0,3"/>
                                    <TextBlock Text="¡Hola Andrés! Listo para jugar" FontSize="13" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                            <Border Background="#0078D4" CornerRadius="8" Padding="10" Margin="50,0,0,8" HorizontalAlignment="Right">
                                <TextBlock Text="Ya elegí la palabra, suerte" FontSize="13" Foreground="White" TextWrapping="Wrap"/>
                            </Border>
                            <Border Background="#F0F0F0" CornerRadius="8" Padding="10" Margin="0,0,50,8" HorizontalAlignment="Left">
                                <StackPanel>
                                    <TextBlock Text="Carlos" FontSize="11" FontWeight="Bold" Foreground="#555555" Margin="0,0,0,3"/>
                                    <TextBlock Text="Voy con la E primero" FontSize="13" TextWrapping="Wrap"/>
                                </StackPanel>
                            </Border>
                        </StackPanel>
                    </ScrollViewer>
                    <Border Grid.Row="2" BorderBrush="#EEEEEE" BorderThickness="0,1,0,0" Padding="10">
                        <Grid>
                            <Grid.ColumnDefinitions>
                                <ColumnDefinition Width="*"/>
                                <ColumnDefinition Width="Auto"/>
                            </Grid.ColumnDefinitions>
                            <TextBox x:Name="txtMensaje" Grid.Column="0" FontSize="13" Padding="8,6" BorderBrush="#DDDDDD" BorderThickness="1" VerticalContentAlignment="Center">
                                <TextBox.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="5"/>
                                    </Style>
                                </TextBox.Resources>
                            </TextBox>
                            <Button Grid.Column="1" Content="►" Width="36" Height="36" Background="#0078D4" Foreground="White" BorderThickness="0" Margin="8,0,0,0" FontSize="14" Click="btnEnviarMensaje_Click">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="18"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </Grid>
                    </Border>
                </Grid>
            </Border>
        </Grid>
    </Grid>
</Window>