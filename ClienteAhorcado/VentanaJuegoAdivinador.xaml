                    <Button Content="H" Width="48" Height="48" FontSize="14" FontWeight="Bold" Background="White" BorderBrush="#CCCCCC" BorderThickness="1" Margin="3" Click="btnLetra_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
