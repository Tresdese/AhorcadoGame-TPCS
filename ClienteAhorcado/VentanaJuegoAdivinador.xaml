<Window x:Class="ClienteAhorcado.VentanaJuegoAdivinador"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ClienteAhorcado"
        mc:Ignorable="d"
        Title="Ahorcado · Partida en curso" Height="650" Width="1000"
        WindowStartupLocation="CenterScreen" Background="#F0F0F0">
    <Grid>
        <Grid.ColumnDefinitions>
            <ColumnDefinition Width="*"/>
            <ColumnDefinition Width="300"/>
        </Grid.ColumnDefinitions>

        <Grid Grid.Column="0">
            <Grid.RowDefinitions>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="*"/>
                <RowDefinition Height="Auto"/>
                <RowDefinition Height="Auto"/>
            </Grid.RowDefinitions>

            <Grid Grid.Row="0" Background="White" Margin="0,0,0,1">
                <Border BorderBrush="#EEEEEE" BorderThickness="0,0,0,1">
                    <Grid Margin="15,10,15,10">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                            <Border Width="36" Height="36" CornerRadius="18" Background="#555555" Margin="0,0,10,0">
                                <TextBlock Text="AS" FontSize="13" FontWeight="Bold" Foreground="White" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                            </Border>
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock Text="Tú (adivinando)" FontSize="14" FontWeight="Bold"/>
                                <TextBlock x:Name="lblRival" Text="" FontSize="12" Foreground="#666666"/>
                            </StackPanel>
                        </StackPanel>
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                            <Border BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="5" Padding="12,6" Margin="0,0,10,0">
                                <TextBlock x:Name="lblIntentos" Text="6  intentos restantes" FontSize="13" FontWeight="Bold"/>
                            </Border>
                            <Button Content="Abandonar partida" Padding="12,6" Background="#D32F2F" Foreground="White" BorderThickness="0" FontSize="13" FontWeight="Bold" Click="btnAbandonar_Click">
                                <Button.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="5"/>
                                    </Style>
                                </Button.Resources>
                            </Button>
                        </StackPanel>
                    </Grid>
                </Border>
            </Grid>

            <Border Grid.Row="1" Background="White" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="5" Margin="15,10,15,0" Padding="15,10">
                <Grid>
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="Auto"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>
                    <StackPanel Grid.Column="0" Margin="0,0,30,0">
                        <TextBlock Text="CATEGORÍA" FontSize="11" FontWeight="Bold" Foreground="#888888"/>
                        <TextBlock x:Name="lblCategoria" Text="" FontSize="14" FontWeight="Bold" Margin="0,4,0,0"/>
                    </StackPanel>
                    <StackPanel Grid.Column="1">
                        <TextBlock Text="DESCRIPCIÓN" FontSize="11" FontWeight="Bold" Foreground="#888888"/>
                        <TextBlock x:Name="lblDescripcion" Text="" FontSize="14" TextWrapping="Wrap" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>
            </Border>

            <Image Grid.Row="2" Source="/Recursos/ahorcado_vacio.png" Width="180" Height="180" HorizontalAlignment="Center" VerticalAlignment="Center" x:Name="imgAhorcado"/>

            <WrapPanel Grid.Row="3" HorizontalAlignment="Center" Margin="15,5,15,10">
                <Border BorderBrush="#333333" BorderThickness="0,0,0,2" Width="45" Height="55" Margin="3">
                    <TextBlock x:Name="l1" Text="" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <Border BorderBrush="#333333" BorderThickness="0,0,0,2" Width="45" Height="55" Margin="3">
                    <TextBlock x:Name="l2" Text="" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <Border BorderBrush="#333333" BorderThickness="0,0,0,2" Width="45" Height="55" Margin="3">
                    <TextBlock x:Name="l3" Text="" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <Border BorderBrush="#333333" BorderThickness="0,0,0,2" Width="45" Height="55" Margin="3">
                    <TextBlock x:Name="l4" Text="" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <Border BorderBrush="#333333" BorderThickness="0,0,0,2" Width="45" Height="55" Margin="3">
                    <TextBlock x:Name="l5" Text="" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <Border BorderBrush="#333333" BorderThickness="0,0,0,2" Width="45" Height="55" Margin="3">
                    <TextBlock x:Name="l6" Text="" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <Border BorderBrush="#333333" BorderThickness="0,0,0,2" Width="45" Height="55" Margin="3">
                    <TextBlock x:Name="l7" Text="" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
                <Border BorderBrush="#333333" BorderThickness="0,0,0,2" Width="45" Height="55" Margin="3">
                    <TextBlock x:Name="l8" Text="" FontSize="22" HorizontalAlignment="Center" VerticalAlignment="Center"/>
                </Border>
            </WrapPanel>

            <StackPanel Grid.Row="4" Margin="15,0,15,15">
                <WrapPanel HorizontalAlignment="Center" Margin="0,0,0,5">
                    <Button Content="Q" Width="48" Height="48" FontSize="14" FontWeight="Bold" Background="White" BorderBrush="#CCCCCC" BorderThickness="1" Margin="3" Click="btnLetra_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button Content="W" Width="48" Height="48" FontSize="14" FontWeight="Bold" Background="White" BorderBrush="#CCCCCC" BorderThickness="1" Margin="3" Click="btnLetra_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <Button Content="E" Width="48" Height="48" FontSize="14" FontWeight="Bold" Background="White" BorderBrush="#CCCCCC" BorderThickness="1" Margin="3" Click="btnLetra_Click">
