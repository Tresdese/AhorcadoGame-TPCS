<Window x:Class="ClienteAhorcado.VentanaRegistrarCuenta"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ClienteAhorcado"
        mc:Ignorable="d"
        Title="Ahorcado" Height="600" Width="1000"
        WindowStartupLocation="CenterScreen" Background="#F0F0F0">

    <Grid Margin="20">
        <Button Content="⇐ Volver" HorizontalAlignment="Left" VerticalAlignment="Top" Padding="10,5" Background="White" Foreground="Black"
                BorderBrush="#CCCCCC" BorderThickness="1" FontSize="13" Click="btnVolver_Click">
            <Button.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="5"/>
                </Style>
            </Button.Resources>
        </Button>

        <Button Content="🌐 ES" HorizontalAlignment="Right" VerticalAlignment="Top" Padding="10,5" Background="White"
                Foreground="Black" BorderBrush="#CCCCCC" BorderThickness="1" FontSize="13">
            <Button.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="5"/>
                </Style>
            </Button.Resources>
        </Button>

        <ScrollViewer VerticalScrollBarVisibility="Auto" Margin="0,50,0,0">
            <StackPanel HorizontalAlignment="Center" Width="800" Margin="0,20,0,20">

                <TextBlock Text="Crear una cuenta" FontSize="28" FontWeight="Bold" HorizontalAlignment="Center"/>
                
                <TextBlock Text="Sólo unos datos y ya puedes empezar a jugar." FontSize="14" Foreground="#666666" HorizontalAlignment="Center" Margin="0,5,0,25"/>

                <TextBlock x:Name="lblNombre" Text="Nombre completo" FontSize="13" Foreground="#333333" Margin="0,0,0,5"/>
                
                <TextBox x:Name="txtNombre" FontSize="14" Height="40" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#CCCCCC" BorderThickness="1">
                    <TextBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>
                
                <TextBlock x:Name="lblErrorNombre" Text="Este campo es obligatorio." Foreground="Red" FontSize="12" Visibility="Collapsed" Margin="0,4,0,0"/>

                <Grid Margin="0,15,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock x:Name="lblCorreo" Text="Correo electrónico" FontSize="13" Foreground="#333333" Margin="0,0,0,5"/>
                        
                        <TextBox x:Name="txtCorreo" FontSize="14" Height="40" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#CCCCCC" BorderThickness="1">
                            <TextBox.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="5"/>
                                </Style>
                            </TextBox.Resources>
                        </TextBox>
                        
                        <TextBlock x:Name="lblErrorCorreo" Text="Este correo ya tiene una cuenta asociada." Foreground="Red" FontSize="12" Visibility="Collapsed" TextWrapping="Wrap" Margin="0,4,0,0"/>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock x:Name="lblFecha" Text="Fecha de nacimiento" FontSize="13" Foreground="#333333" Margin="0,0,0,5"/>
                        
                        <DatePicker x:Name="dpFechaNacimiento" FontSize="14" Height="40" BorderBrush="#CCCCCC" BorderThickness="1">
                            <DatePicker.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="5"/>
                                </Style>
                            </DatePicker.Resources>
                        </DatePicker>
                        
                        <TextBlock x:Name="lblErrorFecha" Text="Debes tener al menos 10 años cumplidos para registrarte." Foreground="Red" FontSize="12" Visibility="Collapsed" TextWrapping="Wrap" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>

                <TextBlock x:Name="lblCelular" Text="Número de celular" FontSize="13" Foreground="#333333" Margin="0,15,0,5"/>
                
                <TextBox x:Name="txtCelular" FontSize="14" Height="40" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#CCCCCC" BorderThickness="1" Width="390" HorizontalAlignment="Left">
                    <TextBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>
                
                <TextBlock x:Name="lblErrorCelular" Text="Este campo es obligatorio." Foreground="Red" FontSize="12" Visibility="Collapsed" Margin="0,4,0,0"/>

                <Grid Margin="0,15,0,0">
                    <Grid.ColumnDefinitions>
                        <ColumnDefinition Width="*"/>
                        <ColumnDefinition Width="20"/>
                        <ColumnDefinition Width="*"/>
                    </Grid.ColumnDefinitions>

                    <StackPanel Grid.Column="0">
                        <TextBlock x:Name="lblContrasena" Text="Contraseña" FontSize="13" Foreground="#333333" Margin="0,0,0,5"/>
                        
                        <PasswordBox x:Name="txtContrasena" FontSize="14" Height="40" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#CCCCCC" BorderThickness="1">
                            <PasswordBox.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="5"/>
                                </Style>
                            </PasswordBox.Resources>
                        </PasswordBox>
                    </StackPanel>

                    <StackPanel Grid.Column="2">
                        <TextBlock x:Name="lblConfirmar" Text="Confirmar contraseña" FontSize="13" Foreground="#333333" Margin="0,0,0,5"/>
                        
                        <PasswordBox x:Name="txtConfirmarContrasena" FontSize="14" Height="40" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#CCCCCC" BorderThickness="1">
                            <PasswordBox.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="5"/>
                                </Style>
                            </PasswordBox.Resources>
                        </PasswordBox>
                        
                        <TextBlock x:Name="lblErrorContrasena" Text="Las contraseñas no coinciden." Foreground="Red" FontSize="12" Visibility="Collapsed" Margin="0,4,0,0"/>
                    </StackPanel>
                </Grid>

                <Border Background="#F5F5F5" BorderBrush="#DDDDDD" BorderThickness="1" CornerRadius="5" Padding="15" Margin="0,15,0,0">
                    <StackPanel>
                        <TextBlock Text="TU CONTRASEÑA DEBE TENER:" FontSize="12" FontWeight="Bold" Foreground="#333333" Margin="0,0,0,8"/>
                        
                        <WrapPanel>
                            <CheckBox x:Name="chk8Caracteres" Content="Al menos 8 caracteres" FontSize="12" IsEnabled="False" Margin="0,0,20,0"/>
                            <CheckBox x:Name="chkMayuscula" Content="Una letra mayúscula" FontSize="12" IsEnabled="False" Margin="0,0,20,0"/>
                            <CheckBox x:Name="chkMinuscula" Content="Una letra minúscula" FontSize="12" IsEnabled="False" Margin="0,0,20,0"/>
                            <CheckBox x:Name="chkNumero" Content="Un número" FontSize="12" IsEnabled="False"/>
                        </WrapPanel>
                    </StackPanel>
                </Border>

                <Button x:Name="btnRegistrar" Content="Registrar cuenta" Height="45" Background="#0078D4" Foreground="White"
                        BorderThickness="0" FontSize="15" FontWeight="Bold" Margin="0,20,0,0" Click="btnRegistrar_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                    <TextBlock Text="¿Ya tienes cuenta? " FontSize="13" Foreground="#444444"/>

                    <TextBlock Text="Inicia sesión" FontSize="13" Foreground="#0078D4" TextDecorations="Underline" FontWeight="Bold" Cursor="Hand">
                        <TextBlock.InputBindings>
                            <MouseBinding MouseAction="LeftClick" Command="{x:Null}"/>
                        </TextBlock.InputBindings>
                    </TextBlock>
                </StackPanel>
            </StackPanel>
        </ScrollViewer>
    </Grid>
</Window>