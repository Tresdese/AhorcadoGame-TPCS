<Window x:Class="ClienteAhorcado.DialogoPerdedorAdivinador"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ClienteAhorcado"
        mc:Ignorable="d"
        Title="" Height="480" Width="500"
        WindowStartupLocation="CenterOwner"
        ResizeMode="NoResize" WindowStyle="None"
        Background="Transparent" AllowsTransparency="True">
    <Border Background="White" CornerRadius="10" Padding="30">
        <Border.Effect>
            <DropShadowEffect BlurRadius="20" Opacity="0.2" ShadowDepth="5"/>
        </Border.Effect>
        <StackPanel>
            <Border Background="#FFF8E1" CornerRadius="8" Width="55" Height="55" HorizontalAlignment="Center" Margin="0,0,0,15">
                <TextBlock Text="☹" FontSize="26" HorizontalAlignment="Center" VerticalAlignment="Center" Foreground="#888888"/>
            </Border>
            <TextBlock Text="Se acabaron los intentos" FontSize="20" FontWeight="Bold" HorizontalAlignment="Center" Margin="0,0,0,5"/>
            <TextBlock Text="No sumaste puntos esta vez" FontSize="13" Foreground="#555555" HorizontalAlignment="Center" Margin="0,0,0,15"/>
            <Border Background="#F9F9F9" BorderBrush="#EEEEEE" BorderThickness="1" CornerRadius="5" Padding="15,10" Margin="0,0,0,20">
                <StackPanel>
                    <Grid Margin="0,0,0,8">
                        <TextBlock Text="Palabra" FontSize="13" Foreground="#888888" HorizontalAlignment="Left"/>
                        <TextBlock x:Name="txtPalabra" Text="ELEFANTE" FontSize="13" FontWeight="Bold" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid Margin="0,0,0,8">
                        <TextBlock Text="Rival" FontSize="13" Foreground="#888888" HorizontalAlignment="Left"/>
                        <TextBlock x:Name="txtRival" Text="Carlos Mendoza" FontSize="13" FontWeight="Bold" HorizontalAlignment="Right"/>
                    </Grid>
                    <Grid Margin="0,0,0,15">
                        <TextBlock Text="Categoría" FontSize="13" Foreground="#888888" HorizontalAlignment="Left"/>
                        <TextBlock x:Name="txtCategoria" Text="Animales" FontSize="13" FontWeight="Bold" HorizontalAlignment="Right"/>
                    </Grid>
                    <Border BorderBrush="#EEEEEE" BorderThickness="0,1,0,0" Padding="0,10,0,0">
                        <StackPanel>
                            <Grid Margin="0,0,0,5">
                                <TextBlock Text="Puntos obtenidos" FontSize="13" Foreground="#888888" HorizontalAlignment="Left"/>
                                <TextBlock x:Name="txtPuntosObtenidos" Text="0 pts" FontSize="13" FontWeight="Bold" HorizontalAlignment="Right"/>
                            </Grid>
                            <Grid>
                                <TextBlock Text="Puntaje global" FontSize="13" Foreground="#888888" HorizontalAlignment="Left"/>
                                <TextBlock x:Name="txtPuntajeGlobal" Text="75 pts" FontSize="13" FontWeight="Bold" HorizontalAlignment="Right"/>
                            </Grid>
                        </StackPanel>
                    </Border>
                </StackPanel>
            </Border>
            <TextBlock FontSize="13" Foreground="#555555" HorizontalAlignment="Center" Margin="0,0,0,15">
                <Run Text="¿Quieres jugar otra partida con "/>
                <Run x:Name="txtPreguntaRival" Text="Carlos Mendoza" FontWeight="Bold"/>
                <Run Text="?"/>
            </TextBlock>
            <Button Content="Ir al lobby" Height="40" Background="#0078D4" Foreground="White" BorderThickness="0" FontSize="13" FontWeight="Bold" Click="btnLobby_Click">
                <Button.Resources>
                    <Style TargetType="Border">
                        <Setter Property="CornerRadius" Value="5"/>
                    </Style>
                </Button.Resources>
            </Button>
        </StackPanel>
    </Border>
</Window>
