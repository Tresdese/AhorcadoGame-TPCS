<Page x:Class="ClienteAhorcado.VentanaEditarPerfil"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ClienteAhorcado"
        xmlns:p="clr-namespace:ClienteAhorcado.Properties"
        mc:Ignorable="d" Background="#F0F0F0">
    <Grid>
        <Grid.RowDefinitions>
            <RowDefinition Height="Auto"/>
            <RowDefinition Height="*"/>
        </Grid.RowDefinitions>
        <Grid Grid.Row="0" Background="White">
            <Border BorderBrush="#EEEEEE" BorderThickness="0,0,0,1">
                <Grid Margin="20,12,20,12">
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Left" VerticalAlignment="Center">
                        <Button Content="{x:Static p:Resources.Comun_Volver}" Padding="10,5" Background="White" Foreground="Black" BorderBrush="#CCCCCC" BorderThickness="1" FontSize="13" Margin="0,0,15,0" Click="btnVolver_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="5"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                        <StackPanel>
                            <TextBlock Text="{x:Static p:Resources.EditarPerfil_Titulo}" FontSize="16" FontWeight="Bold"/>
                            <TextBlock Text="{x:Static p:Resources.EditarPerfil_Subtitulo}" FontSize="12" Foreground="#666666"/>
                        </StackPanel>
                    </StackPanel>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" VerticalAlignment="Center">
                        <Button x:Name="btnIdioma" Click="btnIdioma_Click" Padding="10,5" Background="White" Foreground="Black" BorderBrush="#CCCCCC" BorderThickness="1" FontSize="13" Margin="0,0,10,0">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="5"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                        <Button x:Name="btnUsuario" Content="Usuario ▼" Padding="10,5" Background="#333333" Foreground="White" BorderThickness="0" FontSize="13">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="20"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </Grid>
            </Border>
        </Grid>
        <ScrollViewer Grid.Row="1" VerticalScrollBarVisibility="Auto" Margin="20">
            <Border Background="White" CornerRadius="8" Padding="30">
                <Border.Effect>
                    <DropShadowEffect BlurRadius="10" Opacity="0.08" ShadowDepth="2"/>
                </Border.Effect>
                <StackPanel>
                    <Grid Margin="0,0,0,25">
                        <StackPanel Orientation="Horizontal" HorizontalAlignment="Left">
                            <StackPanel VerticalAlignment="Center">
                                <TextBlock x:Name="lblNombreEncabezado" Text="Andrés Sánchez" FontSize="18" FontWeight="Bold"/>
                                <TextBlock x:Name="lblCorreoEncabezado" Text="andressv@ejemplo.com" FontSize="13" Foreground="#666666"/>
                            </StackPanel>
                        </StackPanel>
                        <Border HorizontalAlignment="Right" VerticalAlignment="Center" Background="#333333" CornerRadius="5" Padding="12,6">
                            <TextBlock Text="{x:Static p:Resources.EditarPerfil_Editando}" FontSize="12" FontWeight="Bold" Foreground="White"/>
                        </Border>
                    </Grid>
                    <TextBlock Text="{x:Static p:Resources.RegistrarCuenta_NombreCompleto}" FontSize="13" Foreground="#555555" Margin="0,0,0,5"/>
                    <TextBox x:Name="txtNombre" Text="" FontSize="14" Height="40" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#CCCCCC" BorderThickness="1">
                        <TextBox.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </TextBox.Resources>
                    </TextBox>
                    <TextBlock x:Name="lblErrorNombre" Text="{x:Static p:Resources.Comun_CampoObligatorio}" Foreground="Red" FontSize="12" Visibility="Collapsed" Margin="0,4,0,0"/>
                    <Grid Margin="0,15,0,0">
                        <Grid.ColumnDefinitions>
                            <ColumnDefinition Width="*"/>
                            <ColumnDefinition Width="20"/>
                            <ColumnDefinition Width="*"/>
                        </Grid.ColumnDefinitions>
                        <StackPanel Grid.Column="0">
                            <TextBlock Text="{x:Static p:Resources.RegistrarCuenta_FechaNacimiento}" FontSize="13" Foreground="#555555" Margin="0,0,0,5"/>
                            <DatePicker x:Name="dpFechaNacimiento" FontSize="14" Height="40" BorderBrush="#CCCCCC" BorderThickness="1">
                                <DatePicker.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="5"/>
                                    </Style>
                                </DatePicker.Resources>
                            </DatePicker>
                            <TextBlock x:Name="lblErrorFecha" Text="{x:Static p:Resources.RegistrarCuenta_ErrorFechaVacia}" Foreground="Red" FontSize="12" Visibility="Collapsed" Margin="0,4,0,0"/>
                        </StackPanel>
                        <StackPanel Grid.Column="2">
                            <TextBlock Text="{x:Static p:Resources.RegistrarCuenta_NumeroCelular}" FontSize="13" Foreground="#555555" Margin="0,0,0,5"/>
                            <TextBox x:Name="txtCelular" Text="" FontSize="14" Height="40" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#CCCCCC" BorderThickness="1">
                                <TextBox.Resources>
                                    <Style TargetType="Border">
                                        <Setter Property="CornerRadius" Value="5"/>
                                    </Style>
                                </TextBox.Resources>
                            </TextBox>
                            <TextBlock x:Name="lblErrorCelular" Text="{x:Static p:Resources.RegistrarCuenta_ErrorCelularInvalido}" Foreground="Red" FontSize="12" Visibility="Collapsed" Margin="0,4,0,0"/>
                        </StackPanel>
                    </Grid>
                    <Button x:Name="btnCambiarContrasena" Content="{x:Static p:Resources.EditarPerfil_CambiarContrasena}" HorizontalAlignment="Left" Padding="15,8" Margin="0,20,0,0" Background="White" Foreground="#0078D4" BorderBrush="#0078D4" BorderThickness="1" FontSize="13" FontWeight="Bold" Click="btnCambiarContrasena_Click">
                        <Button.Resources>
                            <Style TargetType="Border">
                                <Setter Property="CornerRadius" Value="5"/>
                            </Style>
                        </Button.Resources>
                    </Button>
                    <StackPanel Orientation="Horizontal" HorizontalAlignment="Right" Margin="0,25,0,0">
                        <Button Content="{x:Static p:Resources.Comun_Cancelar}" Padding="15,8" Background="White" Foreground="#333333" BorderBrush="#CCCCCC" BorderThickness="1" FontSize="14" Margin="0,0,10,0" Click="btnCancelar_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="5"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                        <Button x:Name="btnGuardar" Content="{x:Static p:Resources.EditarPerfil_GuardarCambios}" Padding="15,8" Background="#0078D4" Foreground="White" BorderThickness="0" FontSize="14" FontWeight="Bold" Click="btnGuardar_Click">
                            <Button.Resources>
                                <Style TargetType="Border">
                                    <Setter Property="CornerRadius" Value="5"/>
                                </Style>
                            </Button.Resources>
                        </Button>
                    </StackPanel>
                </StackPanel>
            </Border>
        </ScrollViewer>
    </Grid>
</Page>