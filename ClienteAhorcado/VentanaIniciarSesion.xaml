<Window x:Class="ClienteAhorcado.VentanaIniciarSesion"
        xmlns="http://schemas.microsoft.com/winfx/2006/xaml/presentation"
        xmlns:x="http://schemas.microsoft.com/winfx/2006/xaml"
        xmlns:d="http://schemas.microsoft.com/expression/blend/2008"
        xmlns:mc="http://schemas.openxmlformats.org/markup-compatibility/2006"
        xmlns:local="clr-namespace:ClienteAhorcado"
        xmlns:p="clr-namespace:ClienteAhorcado.Properties"
        mc:Ignorable="d"
        Title="Ahorcado" Height="600" Width="900"
        WindowStartupLocation="CenterScreen" Background="#F0F0F0">

    <Grid Margin="20">
        <Button Content="{x:Static p:Resources.Comun_Volver}" HorizontalAlignment="Left" VerticalAlignment="Top" Padding="10,5" Background="White" Foreground="Black"
                BorderBrush="#CCCCCC" BorderThickness="1" FontSize="13" Click="btnVolver_Click">
            <Button.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="5"/>
                </Style>
            </Button.Resources>
        </Button>

        <Button x:Name="btnIdioma" Click="btnIdioma_Click" HorizontalAlignment="Right" VerticalAlignment="Top" Padding="10,5" Background="White"
                Foreground="Black" BorderBrush="#CCCCCC" BorderThickness="1" FontSize="13">
            <Button.Resources>
                <Style TargetType="Border">
                    <Setter Property="CornerRadius" Value="5"/>
                </Style>
            </Button.Resources>
        </Button>

        <Border HorizontalAlignment="Center" VerticalAlignment="Center" Background="White" CornerRadius="10" Padding="40" Width="500">
            <Border.Effect>
                <DropShadowEffect BlurRadius="15" Opacity="0.1" ShadowDepth="3"/>
            </Border.Effect>
            <StackPanel>
                <Image Source="/Recursos/ahorcado_sextoFallido.png" Width="70" Height="75" HorizontalAlignment="Center" Margin="0,0,0,15"/>

                <TextBlock Text="{x:Static p:Resources.Comun_IniciarSesion}" FontSize="26" FontWeight="Bold" HorizontalAlignment="Center"/>

                <TextBlock Text="{x:Static p:Resources.IniciarSesion_Subtitulo}" FontSize="14" Foreground="#666666" HorizontalAlignment="Center" Margin="0,4,0,20"/>

                <TextBlock x:Name="lblCorreo" Text="{x:Static p:Resources.Comun_CorreoElectronico}" FontSize="13" Foreground="#333333" Margin="0,0,0,5"/>

                <TextBox x:Name="txtCorreo" FontSize="14" Height="40" Padding="8,0" VerticalContentAlignment="Center" BorderBrush="#CCCCCC" BorderThickness="1">
                    <TextBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </TextBox.Resources>
                </TextBox>

                <TextBlock x:Name="lblErrorCorreo" Text="{x:Static p:Resources.IniciarSesion_ErrorCorreo}"
                           Foreground="Red" FontSize="12" Visibility="Collapsed" TextWrapping="Wrap" Margin="0,4,0,0"/>

                <TextBlock x:Name="lblContrasena" Text="{x:Static p:Resources.Comun_Contrasena}" FontSize="13" Foreground="#333333" Margin="0,15,0,5"/>

                <PasswordBox x:Name="txtContrasena" FontSize="14" Height="40" Padding="8,0"
                             VerticalContentAlignment="Center" BorderBrush="#CCCCCC" BorderThickness="1">
                    <PasswordBox.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </PasswordBox.Resources>
                </PasswordBox>

                <TextBlock x:Name="lblErrorContrasena" Text="{x:Static p:Resources.IniciarSesion_ErrorContrasena}"
                           Foreground="Red" FontSize="12" Visibility="Collapsed" Margin="0,4,0,0"/>

                <Button x:Name="btnIniciarSesion" Content="{x:Static p:Resources.Comun_IniciarSesion}" Height="40" Background="#0078D4" Foreground="White" BorderThickness="0"
                        FontSize="14" FontWeight="Bold" Margin="0,20,0,0" Click="btnIniciarSesion_Click">
                    <Button.Resources>
                        <Style TargetType="Border">
                            <Setter Property="CornerRadius" Value="5"/>
                        </Style>
                    </Button.Resources>
                </Button>

                <StackPanel Orientation="Horizontal" HorizontalAlignment="Center" Margin="0,15,0,0">
                    <TextBlock Text="{x:Static p:Resources.IniciarSesion_NoTienesCuenta}" FontSize="13" Foreground="#444444"/>
                    <TextBlock Text="{x:Static p:Resources.Comun_Registrate}" FontSize="13" Foreground="#0078D4" TextDecorations="Underline" FontWeight="Bold" Cursor="Hand"
                               MouseLeftButtonDown="lnkRegistrate_Click"/>
                </StackPanel>
            </StackPanel>
        </Border>
    </Grid>
</Window>